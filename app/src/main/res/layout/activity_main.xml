<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    tools:context=".MainActivity">

    <!-- Header Panel -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SHEPARD KEYBOARD"
            android:textColor="#FFCC00"
            android:textStyle="bold"
            android:textSize="18sp"
            android:letterSpacing="0.2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="16dp"/>

        <!-- Audio Player Panel (Hidden by default) -->
        <LinearLayout
            android:id="@+id/layout_audio_player"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintStart_toEndOf="@id/tv_title"
            app:layout_constraintEnd_toStartOf="@id/top_button_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/ib_audio_play_pause"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_play"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:scaleType="fitCenter" />

            <ImageButton
                android:id="@+id/ib_audio_stop"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_stop"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="4dp"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tv_audio_name"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="No file"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:ellipsize="end"
                android:singleLine="true"
                android:layout_marginStart="4dp" />

            <SeekBar
                android:id="@+id/seek_audio_position"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="0"
                android:progressTint="#FFCC00"
                android:thumbTint="#FFCC00" />

            <TextView
                android:id="@+id/tv_audio_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00/00:00"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/top_button_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="8dp">

            <Button
                android:id="@+id/btn_main_share"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="SHARE"
                android:textColor="#888888"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btn_main_ads"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="ADS"
                android:textColor="#888888"
                android:textSize="10sp"
                android:layout_marginStart="4dp"/>

            <ImageButton
                android:id="@+id/ib_save"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_save"
                android:tint="#888888"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:scaleType="fitCenter" />
            <ImageButton
                android:id="@+id/ib_load"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_load"
                android:tint="#888888"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="4dp"
                android:padding="8dp"
                android:scaleType="fitCenter" />
            <ImageButton
                android:id="@+id/ib_settings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_settings"
                android:tint="#888888"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="4dp"
                android:padding="8dp"
                android:scaleType="fitCenter" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Master Controls Area (Dashboard) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/dashboard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/header_panel"
        app:layout_constraintBottom_toTopOf="@+id/keyboard_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Performance Sliders (Left) -->
        <LinearLayout
            android:id="@+id/perf_sliders"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:background="#222222"
            android:padding="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Pitch Bend (Vertical) -->
            <LinearLayout
                android:id="@+id/performance_pitch_container"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PITCH" android:textColor="#666666" android:textSize="9sp"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">
                    <SeekBar
                        android:id="@+id/seek_pitch_bend"
                        android:layout_width="140dp"
                        android:layout_height="30dp"
                        android:max="200"
                        android:progress="100"
                        android:layout_gravity="center"
                        android:rotation="-90" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BEND" android:textColor="#666666" android:textSize="9sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/performance_mod_container"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MOD" android:textColor="#666666" android:textSize="9sp"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">
                    <SeekBar
                        android:id="@+id/seek_modulation"
                        android:layout_width="140dp"
                        android:layout_height="30dp"
                        android:max="100"
                        android:progress="0"
                        android:layout_gravity="center"
                        android:rotation="-90" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DEPTH" android:textColor="#666666" android:textSize="9sp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/performance_drive_container"
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DRIVE" android:textColor="#FFCC00" android:textSize="9sp" android:textStyle="bold"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1">
                    <SeekBar
                        android:id="@+id/seek_drive"
                        android:layout_width="140dp"
                        android:layout_height="30dp"
                        android:max="100"
                        android:progress="0"
                        android:layout_gravity="center"
                        android:rotation="-90"
                        android:progressTint="#FFCC00"
                        android:thumbTint="#FFCC00" />
                </FrameLayout>
                <TextView android:id="@+id/tv_drive_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textColor="#666666" android:textSize="9sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Osc Settings (Expanded Right) -->
        <LinearLayout
            android:id="@+id/params_panel"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginStart="12dp"
            app:layout_constraintEnd_toStartOf="@id/filter_container"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tv_center_freq" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="600Hz" android:textColor="#FFCC00" android:textSize="8sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tv_sigma" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.00" android:textColor="#FFCC00" android:textSize="8sp" android:textStyle="bold"/>
            </LinearLayout>



            <jp.example.shepardkeyboard.XYPadView
                android:id="@+id/pad_oscillator"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Filter Settings (Far Right) -->
        <LinearLayout
            android:id="@+id/filter_container"
            android:layout_width="160dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginStart="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tv_filter_cutoff" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="1000Hz" android:textColor="#FFCC00" android:textSize="8sp" android:textStyle="bold"/>
                <TextView android:id="@+id/tv_filter_resonance" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.00" android:textColor="#FFCC00" android:textSize="8sp" android:textStyle="bold"/>
            </LinearLayout>

            <jp.example.shepardkeyboard.XYPadView
                android:id="@+id/pad_filter"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Main Display Area (Shrunk Center) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/display_module"
            android:layout_width="180dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            app:cardBackgroundColor="#000000"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            app:layout_constraintStart_toEndOf="@id/perf_sliders"
            app:layout_constraintEnd_toStartOf="@id/params_panel"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                padding="6dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:id="@+id/tv_transpose"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Key: C (0)"
                        android:textColor="#FFCC00"
                        android:textStyle="bold"
                        android:textSize="10sp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_fixed_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="FIXED"
                        android:textColor="#AAAAAA"
                        android:textSize="8sp"
                        app:thumbTint="#FFCC00"
                        app:trackTint="#444444" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_glide"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_marginStart="4dp"
                        android:text="SLIDE"
                        android:textColor="#AAAAAA"
                        android:textSize="8sp"
                        app:thumbTint="#FFCC00"
                        app:trackTint="#444444" />
                </LinearLayout>

                <jp.example.shepardkeyboard.EnvelopeView
                    android:id="@+id/envelope_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/tv_env_values"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="A:0.05 D:0.10 S:0.70 R:0.50"
                    android:textColor="#AAAAAA"
                    android:textSize="7sp"
                    android:gravity="center"
                    android:layout_marginTop="1dp" />
                
                <SeekBar
                    android:id="@+id/seek_transpose"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="12"
                    android:progress="6"
                    android:progressTint="#333333"
                    android:thumbTint="#FFCC00"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Keyboard Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/keyboard_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintHeight_percent="0.45"
        app:layout_constraintTop_toBottomOf="@id/dashboard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- White Keys (With clearer borders) -->
        <View android:id="@+id/key_c" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/key_white_background" app:layout_constraintHorizontal_weight="1" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@+id/key_d" />
        <View android:id="@+id/key_d" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/key_white_background" app:layout_constraintHorizontal_weight="1" app:layout_constraintStart_toEndOf="@+id/key_c" app:layout_constraintEnd_toStartOf="@+id/key_e" />
        <View android:id="@+id/key_e" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/key_white_background" app:layout_constraintHorizontal_weight="1" app:layout_constraintStart_toEndOf="@+id/key_d" app:layout_constraintEnd_toStartOf="@+id/key_f" />
        <View android:id="@+id/key_f" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/key_white_background" app:layout_constraintHorizontal_weight="1" app:layout_constraintStart_toEndOf="@+id/key_e" app:layout_constraintEnd_toStartOf="@+id/key_g" />
        <View android:id="@+id/key_g" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/key_white_background" app:layout_constraintHorizontal_weight="1" app:layout_constraintStart_toEndOf="@+id/key_f" app:layout_constraintEnd_toStartOf="@+id/key_a" />
        <View android:id="@+id/key_a" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/key_white_background" app:layout_constraintHorizontal_weight="1" app:layout_constraintStart_toEndOf="@+id/key_g" app:layout_constraintEnd_toStartOf="@+id/key_b" />
        <View android:id="@+id/key_b" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/key_white_background" app:layout_constraintHorizontal_weight="1" app:layout_constraintStart_toEndOf="@+id/key_a" app:layout_constraintEnd_toEndOf="parent" />

        <!-- Black Keys (Wider: 60dp, and with elevation/shadow) -->
        <View android:id="@+id/key_cs" android:layout_width="60dp" android:layout_height="0dp" android:background="@drawable/key_black_background" android:elevation="6dp" app:layout_constraintHeight_percent="0.65" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toEndOf="@+id/key_c" app:layout_constraintEnd_toEndOf="@+id/key_c" />
        <View android:id="@+id/key_ds" android:layout_width="60dp" android:layout_height="0dp" android:background="@drawable/key_black_background" android:elevation="6dp" app:layout_constraintHeight_percent="0.65" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toEndOf="@+id/key_d" app:layout_constraintEnd_toEndOf="@+id/key_d" />
        <View android:id="@+id/key_fs" android:layout_width="60dp" android:layout_height="0dp" android:background="@drawable/key_black_background" android:elevation="6dp" app:layout_constraintHeight_percent="0.65" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toEndOf="@+id/key_f" app:layout_constraintEnd_toEndOf="@+id/key_f" />
        <View android:id="@+id/key_gs" android:layout_width="60dp" android:layout_height="0dp" android:background="@drawable/key_black_background" android:elevation="6dp" app:layout_constraintHeight_percent="0.65" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toEndOf="@+id/key_g" app:layout_constraintEnd_toEndOf="@+id/key_g" />
        <View android:id="@+id/key_as" android:layout_width="60dp" android:layout_height="0dp" android:background="@drawable/key_black_background" android:elevation="6dp" app:layout_constraintHeight_percent="0.65" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toEndOf="@+id/key_a" app:layout_constraintEnd_toEndOf="@+id/key_a" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>