<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/label_bend_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pitch Bend Range (semitones)" />
        <SeekBar
            android:id="@+id/seek_bend_range"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="6"
            android:progress="2" />

        <TextView
            android:id="@+id/label_bend_slew"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pitch Bend Smoothing"
            android:layout_marginTop="8dp" />
        <SeekBar
            android:id="@+id/seek_bend_slew"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50" />

        <TextView
            android:id="@+id/label_modulation_depth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max Modulation Depth (semitones)"
            android:layout_marginTop="8dp" />
        <SeekBar
            android:id="@+id/seek_modulation_depth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="0" />

        <TextView
            android:id="@+id/label_modulation_rate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modulation Rate (Hz)"
            android:layout_marginTop="8dp" />
        <SeekBar
            android:id="@+id/seek_modulation_rate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="50" />

        <Switch
            android:id="@+id/switch_mono"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monophonic Mode"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/label_buffer_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buffer Size (Frames)"
            android:layout_marginTop="8dp" />
        <SeekBar
            android:id="@+id/seek_buffer_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1024"
            android:min="64" />

        <Switch
            android:id="@+id/switch_recording_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recording Optimization Mode"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="* Enable this if using screen recording."
            android:textSize="12sp"
            android:textColor="#888888" />

        <TextView
            android:id="@+id/label_glide_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Glide Time (ms)"
            android:layout_marginTop="8dp" />
        <SeekBar
            android:id="@+id/seek_glide_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1000"
            android:progress="100" />

        <Button
            android:id="@+id/btn_apply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apply and Regenerate"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
