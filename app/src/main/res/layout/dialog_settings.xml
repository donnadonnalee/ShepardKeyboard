<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- CARD 1: BUFFER & SYSTEM -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#22888888"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BUFFER &amp; SYSTEM"
                    android:textColor="#FFCC00"
                    android:textStyle="bold"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/label_buffer_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Buffer Size (Frames)"
                    android:layout_marginTop="8dp" />
                <SeekBar
                    android:id="@+id/seek_buffer_size"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="1024"
                    android:min="64" />
                <Switch
                    android:id="@+id/switch_recording_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Recording Optimization Mode"
                    android:layout_marginTop="8dp" />
                <TextView
                    android:id="@+id/label_sample_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sample Rate (Hz)"
                    android:layout_marginTop="8dp" />
                <RadioGroup
                    android:id="@+id/rg_sample_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <RadioButton android:id="@+id/rb_sr_8000" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="8k" android:textSize="10sp" />
                    <RadioButton android:id="@+id/rb_sr_24000" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="24k" android:textSize="10sp" />
                    <RadioButton android:id="@+id/rb_sr_44100" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="44.1k" android:textSize="10sp" />
                    <RadioButton android:id="@+id/rb_sr_48000" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="48k" android:textSize="10sp" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD 2: KEYBOARD VERTICAL CONTROL -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#22888888"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KEYBOARD VERTICAL CONTROL"
                    android:textColor="#FFCC00"
                    android:textStyle="bold"
                    android:textSize="12sp" />
                <RadioGroup
                    android:id="@+id/rg_vertical_control"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">
                    <RadioButton
                        android:id="@+id/rb_vertical_volume"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Volume"
                        android:textSize="12sp" />
                    <RadioButton
                        android:id="@+id/rb_vertical_modulation"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Modulation"
                        android:textSize="12sp" />
                    <RadioButton
                        android:id="@+id/rb_vertical_lpf"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="LPF"
                        android:textSize="12sp" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD 3: EFFECT SETTINGS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#22888888"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EFFECT SETTINGS"
                    android:textColor="#FFCC00"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <!-- PITCH BEND -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="PITCH BEND"
                        android:textColor="#888888"
                        android:textSize="11sp" />
                    <Switch
                        android:id="@+id/switch_pitch_enable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
                <TextView
                    android:id="@+id/label_bend_range"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pitch Bend Range (semitones)"
                    android:layout_marginTop="4dp" />
                <SeekBar
                    android:id="@+id/seek_bend_range"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="6"
                    android:progress="2" />
                <TextView
                    android:id="@+id/label_bend_slew"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pitch Bend Smoothing"
                    android:layout_marginTop="8dp" />
                <SeekBar
                    android:id="@+id/seek_bend_slew"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50" />
                <TextView
                    android:id="@+id/label_glide_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Glide Time (ms)"
                    android:layout_marginTop="8dp" />
                <SeekBar
                    android:id="@+id/seek_glide_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="1000"
                    android:progress="100" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="8dp" />

                <!-- OCTAVE JUMP -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="OCTAVE JUMP"
                        android:textColor="#888888"
                        android:textSize="11sp" />
                    <Switch
                        android:id="@+id/switch_octave_enable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
                <TextView
                    android:id="@+id/label_octave_slew"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Octave Smoothing"
                    android:layout_marginTop="8dp" />
                <SeekBar
                    android:id="@+id/seek_octave_slew"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="50" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="8dp" />

                <!-- MODULATION -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="MODULATION"
                        android:textColor="#888888"
                        android:textSize="11sp" />
                    <Switch
                        android:id="@+id/switch_mod_enable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
                <TextView
                    android:id="@+id/label_modulation_depth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Max Modulation Depth (semitones)"
                    android:layout_marginTop="4dp" />
                <SeekBar
                    android:id="@+id/seek_modulation_depth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="0" />
                <TextView
                    android:id="@+id/label_modulation_rate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Modulation Rate (Hz)"
                    android:layout_marginTop="8dp" />
                <SeekBar
                    android:id="@+id/seek_modulation_rate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="200"
                    android:progress="50" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="8dp" />

                <!-- OVERDRIVE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="OVERDRIVE"
                        android:textColor="#888888"
                        android:textSize="11sp" />
                    <Switch
                        android:id="@+id/switch_drive_enable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
                <TextView
                    android:id="@+id/label_drive_limit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Overdrive Gain Limit"
                    android:layout_marginTop="4dp" />
                <SeekBar
                    android:id="@+id/seek_drive_limit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100"
                    android:progress="100" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="8dp" />

                <!-- FILTER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="RESONANT FILTER"
                        android:textColor="#888888"
                        android:textSize="11sp" />
                    <Switch
                        android:id="@+id/switch_filter_enable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Toggle filter processing and XY pad visibility."
                    android:textColor="#BBBBBB"
                    android:textSize="10sp"
                    android:layout_marginTop="4dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#33FFFFFF" android:layout_marginVertical="8dp" />

                <!-- DELAY -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="DELAY"
                        android:textColor="#888888"
                        android:textSize="11sp" />
                    <Switch
                        android:id="@+id/switch_delay_enable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
                <TextView
                    android:id="@+id/label_delay_wet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delay Wet (Mix)"
                    android:layout_marginTop="4dp" />
                <SeekBar
                    android:id="@+id/seek_delay_wet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100" />
                <TextView
                    android:id="@+id/label_delay_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delay Time (ms)"
                    android:layout_marginTop="8dp" />
                <SeekBar
                    android:id="@+id/seek_delay_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="2000" />
                <TextView
                    android:id="@+id/label_delay_feedback"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Delay Feedback"
                    android:layout_marginTop="8dp" />
                <SeekBar
                    android:id="@+id/seek_delay_feedback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="95" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- CARD 4: SCALE CONFIGURATION -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#22888888"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="SCALE CONFIGURATION"
                        android:textColor="#FFCC00"
                        android:textStyle="bold"
                        android:textSize="12sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_scale_config_enable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Dynamic Options Container -->
                <LinearLayout
                    android:id="@+id/container_scale_options"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable custom scales with uniform layout."
                        android:textColor="#BBBBBB"
                        android:textSize="10sp"
                        android:layout_marginTop="2dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="3"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_c" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C" android:textSize="10sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_cs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C#" android:textSize="10sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_d" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D" android:textSize="10sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_ds" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D#" android:textSize="10sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_e" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="E" android:textSize="10sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_f" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F" android:textSize="10sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_fs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F#" android:textSize="10sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_g" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="G" android:textSize="10sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_gs" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="G#" android:textSize="10sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_a" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A" android:textSize="10sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_as" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A#" android:textSize="10sp" />
                        <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/sw_key_b" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="B" android:textSize="10sp" />
                    </GridLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <Button android:id="@+id/btn_scale_chromatic" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Chromatic" android:textSize="9sp" />
                        <Button android:id="@+id/btn_scale_pentatonic" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Pentatonic" android:textSize="9sp" />
                        <Button android:id="@+id/btn_scale_whole" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_weight="1" android:layout_height="36dp" android:text="Whole Tone" android:textSize="9sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- REMOVE ADS BUTTON -->
        <Button
            android:id="@+id/btn_remove_ads"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remove Ads"
            android:backgroundTint="#FFCC00"
            android:textColor="#000000"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_apply"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Apply Changes"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
